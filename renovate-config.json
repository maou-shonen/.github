{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": ["Global Renovate preset for maou-shonen repos"],
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "docker:pinDigests",
    "schedule:weekly"
  ],
  "labels": ["dependencies"],
  "minimumReleaseAge": "3 days",
  "configMigration": true,
  "platformAutomerge": true,
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Security updates should not be delayed by schedule or minimumReleaseAge",
      "matchCategories": ["security"],
      "schedule": ["at any time"],
      "minimumReleaseAge": "0 days"
    },
    {
      "description": "Automerge patch updates",
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Automerge pin and digest updates",
      "matchUpdateTypes": ["pin", "digest"],
      "automerge": true
    }
  ]
}
